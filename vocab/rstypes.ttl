@prefix rstypes: <http://cnodc-cndoc.dfo-mpo.gc.ca/ocproc2/rstypes.ttl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cnodc: <http://cnodc-cndoc.dfo-mpo.gc.ca/ocproc2/cnodc.ttl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

rstypes:recordSetTypes rdf:type skos:ConceptScheme .

rstypes:requireCoordinate rdf:type rdf:Property ;
  rdfs:domain rstypes:recordSetTypes ;
  rdfs:range skos:Literal .


rstypes:TIME_SERIES  rdf:type skos:Concept ;
  skos:prefLabel "Time Series"@en ;
  rstypes:requireCoordinate "TimeOffset%7CTime" ;
  skos:inScheme rstypes:recordSetTypes .

rstypes:PROFILE  rdf:type skos:Concept ;
  skos:prefLabel "Profile"@en ;
  rstypes:requireCoordinate "Depth%7CPressure" ;
  skos:inScheme rstypes:recordSetTypes .

rstypes:WAVE_SENSORS  rdf:type skos:Concept ;
  skos:prefLabel "Wave Sensors"@en ;
  rstypes:requireCoordinate "WaveSensor" ;
  skos:inScheme rstypes:recordSetTypes .

rstypes:SPECTRAL_WAVE  rdf:type skos:Concept ;
  skos:prefLabel "Wave Spectra"@en ;
  rstypes:requireCoordinate "CentralFrequency" ;
  skos:inScheme rstypes:recordSetTypes .

rstypes:TRAJECTORY  rdf:type skos:Concept ;
  skos:prefLabel "Trajectory"@en ;
  rstypes:requireCoordinate "Latitude" ;
  rstypes:requireCoordinate "Longitude" ;
  rstypes:requireCoordinate "Time%7CTimeOffset" ;
  skos:inScheme rstypes:recordSetTypes .
